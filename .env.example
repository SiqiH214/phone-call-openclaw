OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

PUBLIC_APP_NAME=Phone Call OpenClaw
OPENCLAW_AGENT_NAME=OpenClaw
OPENCLAW_OWNER_NAME=the user
# Optional: override the default realtime system voice/personality.
OPENCLAW_AGENT_VOICE_PROMPT=

# Use a stable HTTPS URL for deployed Vercel sites. Local dev can use OPENCLAW_GATEWAY_URL.
OPENCLAW_HOST=local
OPENCLAW_PUBLIC_URL=https://your-stable-openclaw-domain.example
OPENCLAW_GATEWAY_TOKEN=change-me-before-public-deploy
OPENCLAW_GATEWAY_ORIGIN=https://your-call-site.example
PUBLIC_APP_ORIGIN=https://your-call-site.example
OPENCLAW_BRIDGE_SECRET=change-me-before-public-deploy
# Phone calls default to the same full operator permission set as OpenClaw chat.
# Use "read-only", "none", or a comma-separated custom list such as:
# OPENCLAW_CALL_SCOPES=operator.read,operator.write
OPENCLAW_CALL_SCOPES=all

# Optional artifact generation.
FAL_KEY=your-fal-key-here
FAL_IMAGE_MODEL=fal-ai/nano-banana-2
FAL_VIDEO_MODEL=bytedance/seedance-2.0/fast/text-to-video
FAL_VIDEO_DURATION=4
FAL_VIDEO_ASPECT_RATIO=16:9
FAL_VIDEO_RESOLUTION=720p
PORT=8787
